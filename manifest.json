{
  "manifest_version": 3,
  "name": "MCP Bridge",
  "version": "2.0",
  "description": "Minimal browser bridge for MCP",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:3001/*", "http://127.0.0.1:8080/*"],
  "background": {
    "service_worker": "worker/index.js"
  },
  "content_scripts": [{
    "matches": ["https://chat.deepseek.com/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}